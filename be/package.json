{
  "name": "evx-backend",
  "version": "1.0.0",
  "description": "Express and PostgreSQL API for the EVX E-Vehicle Platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --test tests/*.test.js",
    "db:migrate": "node src/database/migrate.js",
    "db:seed": "npm run db:seed:catalog && node scripts/seed-news.js && node scripts/seed-videos.js && node scripts/seed-courses.js",
    "db:seed:catalog": "node scripts/seed.js",
    "db:test": "node test-database.js"
  },
  "keywords": [
    "electric",
    "vehicles",
    "api",
    "express"
  ],
  "author": "EVX contributors",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
