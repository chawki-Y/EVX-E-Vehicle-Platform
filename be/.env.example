# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=evx_db
DB_USER=evx_user
DB_PASSWORD=evx_password
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=evx_db
# DB_USER=evx_user
# DB_PASSWORD=your_password

# JWT (for future authentication)
# JWT_SECRET=your_jwt_secret_key
# JWT_EXPIRES_IN=24h

# External APIs (for future integrations)
# VEHICLE_DATA_API_KEY=your_api_key
# IMAGE_SERVICE_API_KEY=your_image_api_key